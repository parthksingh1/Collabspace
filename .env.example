# ─── CollabSpace Environment Configuration ───

# Application
NODE_ENV=development
APP_PORT=3000
API_GATEWAY_PORT=4000
WS_GATEWAY_PORT=4001

# Supabase (PostgreSQL)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/collabspace

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CLUSTER_NODES=localhost:6379,localhost:6380,localhost:6381

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=collabspace
KAFKA_GROUP_ID=collabspace-group

# Authentication
JWT_SECRET=your-jwt-secret-min-256-bits
JWT_REFRESH_SECRET=your-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# AI Services
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
AI_PRIMARY_PROVIDER=gemini
AI_FALLBACK_PROVIDER=openai

# Vector Database
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east1-gcp
PINECONE_INDEX=collabspace-memory

# WebRTC
TURN_SERVER_URL=turn:turn.collabspace.io:3478
TURN_USERNAME=collabspace
TURN_CREDENTIAL=your-turn-credential

# Storage
S3_BUCKET=collabspace-assets
S3_REGION=us-east-1
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Email (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key

# Encryption
ENCRYPTION_KEY=your-256-bit-encryption-key
E2E_ENCRYPTION_ENABLED=true
